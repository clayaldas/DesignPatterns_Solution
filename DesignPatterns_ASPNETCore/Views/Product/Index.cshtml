@using DesignPatterns_ASPNETCore.Models.ViewModels;
@model IEnumerable<ProductModel>

@* Creamos un boton que permite agregar un producto nuevo
        Product: es el nombre del controlador y Add es el nombre de un método
        que va que va a estar en controller ProductController
    *@
<div class="row">
    <div class="col-12">
        <a class="btn btn-primary" href="~/Product/Add">Nuevo Producto</a>

    </div>
</div>


<br />

@* Creamos el HTML para mostrar los datos *@
<div class="table-responsive">
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Id Producto</th>
                <th>Nombre</th>
                <th>Unidades en Stock</th>
                <th>Precio por unidad</th>

            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var product in Model)
                {
                    <tr>
                        <td class="text-end">@product.ProductId</td>
                        <td>@product.Name</td>
                        <td class="text-end">@product.UnitsInStock</td>
                        <td class="text-end">@product.UnitPrice</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="text-center text-muted">No hay clientes registrados.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
