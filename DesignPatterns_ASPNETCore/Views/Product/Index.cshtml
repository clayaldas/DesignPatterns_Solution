@using DesignPatterns_ASPNETCore.Models.ViewModels;
@model IEnumerable<ProductModel>

@* Crear un boton que permite agregar un producto *@

<div class="row">
	<div class="col-12">
		<a class="btn btn-primary" href="~/Product/Add">Nuevo Producto</a>

	</div>
</div>

@* Crear el HTML para mostrar los datos de la tabla Products *@
<div class="table-responsive">
	<table class="table table-striped table-bordered">
		<thead class="table-dark">
			<tr>
				<th>Id Producto</th>
				<th>Nombre</th>
				<th>Unidades en Stock</th>
				<th>Precio por Unidad</th>
			</tr>
		</thead>

		</br>
		<tbody>
			@if (Model != null && Model.Any())
			{
				foreach (var product in Model)
				{
					<tr>
						<th>@product.ProductId</th>
						<th>@product.Name</th>
						<th>@product.UnitsInStock</th>
						<th>@product.UnitPrice</th>
					</tr>
				}
			}
			else
			{
				<tr>
					<td colspan="3" class="text-center text-muted">No hay datos registrados.</td>
				</tr>
			}
		</tbody>

	</table>
</div>